{
  "name": "naikan",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run build:web && bun run start",
    "dev:no-db": "bun run build:web && bun run apps/api/src/dev-no-db.ts",
    "start": "bun run apps/api/src/index.ts",
    "build": "bun run build:web",
    "build:web": "bun run --cwd apps/web-admin build",
    "migrate": "node-pg-migrate up",
    "migrate:down": "node-pg-migrate down",
    "seed:admin": "bun run scripts/seed-admin.ts",
    "stack": "bash scripts/dev-stack.sh",
    "smoke": "bun run scripts/smoke.ts",
    "db:check": "bun run scripts/db-check.ts",
    "digest:now": "bun run scripts/digest-now.ts",
    "eval:generate": "node packages/eval-dataset/src/generate.ts",
    "eval:curate": "node packages/eval-dataset/src/curate.ts",
    "eval:seed-demo": "node packages/eval-dataset/src/seed-demo.ts",
    "test": "bun test",
    "typecheck": "bun run --cwd apps/web-admin check"
  },
  "dependencies": {
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "bun-types": "^1.3.14",
    "node-pg-migrate": "^7.9.1",
    "pg": "^8.13.1",
    "typescript": "^5.7.2"
  }
}
