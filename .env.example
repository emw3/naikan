# Postgres connection string.
# Used by the API at runtime (the `postgres` library) and by the migrations
# runner (`node-pg-migrate`, which reads DATABASE_URL by default).
DATABASE_URL=postgres://postgres:postgres@localhost:5432/naikan

# Port the API listens on; the API also serves the built Svelte SPA here in dev.
PORT=3000

# First admin, created by `bun run seed:admin` (after `bun run migrate`).
# Idempotent — re-running with an existing email is a no-op.
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=change-me-in-prod

# S3-compatible artifact storage (baseline-store, issue #04 / ADR-0002).
# Local dev + CI run MinIO (see docker-compose.yml); production uses AWS S3.
# When S3_ENDPOINT is set, path-style addressing is auto-enabled (MinIO needs it);
# leave S3_ENDPOINT empty for real S3. Override path-style with S3_FORCE_PATH_STYLE.
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=naikan-artifacts
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin

# Incident alerting (issue #10 / ADR-0003).
# RESEND_API_KEY: transactional email via Resend (verify the sending domain first).
# ALERT_FROM_EMAIL: the verified "from" address for alert + digest email.
# APP_BASE_URL: public base URL of the dashboard, used for alert deep-links.
# Per-project Slack routing uses the webhook URL stored on each Project (no global env).
# Email sends are best-effort: missing keys don't block boot, they just no-op until set.
RESEND_API_KEY=
ALERT_FROM_EMAIL=alerts@example.com
APP_BASE_URL=http://localhost:3000

# Daily digest (issue #15). DIGEST_CRON is a 5-field cron (UTC) for when the
# per-manager digest fires; MVP is a single global send time (PRD default 08:00).
# Per-Project opt-ins (digest_email_enabled / digest_slack_enabled) gate delivery.
DIGEST_CRON=0 8 * * *

# Self-monitoring /health thresholds (issue #18). Both optional — these are the
# defaults. HEALTH_QUEUE_LAG_SECONDS: max age of the oldest waiting queue job before
# /health reports the queue as lagging. HEALTH_FRESHNESS_MULTIPLIER: the last-run
# freshness window is this × the shortest configured heartbeat interval.
HEALTH_QUEUE_LAG_SECONDS=300
HEALTH_FRESHNESS_MULTIPLIER=2
